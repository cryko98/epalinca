{%- comment -%}
  Zekulhyda SEO enhancements — rendered in <head> on every page.
  Adds: og:locale, og:image:alt, JSON-LD Organization (all pages),
  WebSite + SearchAction (homepage), BreadcrumbList (inner pages).
{%- endcomment -%}

{%- liquid
  assign seo_origin = request.origin | default: shop.url
  assign seo_desc = page_description | default: shop.description | default: shop.name

  assign social_list = ''
  if settings.social_facebook_link != blank
    assign social_list = social_list | append: settings.social_facebook_link | append: '||'
  endif
  if settings.social_instagram_link != blank
    assign social_list = social_list | append: settings.social_instagram_link | append: '||'
  endif
  if settings.social_tiktok_link != blank
    assign social_list = social_list | append: settings.social_tiktok_link | append: '||'
  endif
  if settings.social_youtube_link != blank
    assign social_list = social_list | append: settings.social_youtube_link | append: '||'
  endif
  if settings.social_twitter_link != blank
    assign social_list = social_list | append: settings.social_twitter_link | append: '||'
  endif
  assign socials = social_list | split: '||'

  if settings.logo != blank
    assign seo_logo = settings.logo | image_url: width: 512 | prepend: 'https:'
  elsif settings.favicon != blank
    assign seo_logo = settings.favicon | image_url: width: 192 | prepend: 'https:'
  endif
-%}

<meta property="og:locale" content="ro_RO">
{%- if page_image -%}
  <meta property="og:image:alt" content="{{ page_title | default: shop.name | escape }}">
{%- endif -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  "url": {{ seo_origin | json }},
  {%- if seo_logo %}
  "logo": {{ seo_logo | json }},
  "image": {{ seo_logo | json }},
  {%- endif %}
  "description": {{ seo_desc | json }},
  "founder": { "@type": "Person", "name": "Nagy Botond" }
  {%- if socials.size > 0 %},
  "sameAs": [{% for s in socials %}{{ s | json }}{% unless forloop.last %}, {% endunless %}{% endfor %}]
  {%- endif %}
}
</script>

{%- if request.page_type == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": {{ shop.name | json }},
  "url": {{ seo_origin | json }},
  "inLanguage": "ro-RO",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "{{ seo_origin }}/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
</script>
{%- endif -%}

{%- comment -%} Breadcrumbs for inner pages {%- endcomment -%}
{%- if request.page_type == 'page' or request.page_type == 'product' or request.page_type == 'collection' or request.page_type == 'article' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Acasă",
      "item": {{ seo_origin | json }}
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ page_title | default: shop.name | json }},
      "item": {{ canonical_url | default: seo_origin | json }}
    }
  ]
}
</script>
{%- endif -%}
