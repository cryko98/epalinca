<link rel="stylesheet" href="{{ 'zekulhyda.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'zekulhyda.css' | asset_url | stylesheet_tag }}</noscript>

<section class="zk-story" id="zk-story">
  <div class="zk-story__inner zk-reveal" data-zk-reveal>
    <span class="zk-story__label">{{ section.settings.label }}</span>

    <h2 class="zk-story__title zk-shimmer">{{ section.settings.title }}</h2>

    <span class="zk-story__ornament" aria-hidden="true">
      <svg viewBox="0 0 120 16" fill="none" xmlns="http://www.w3.org/2000/svg" focusable="false">
        <path d="M2 8h40" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.5"/>
        <path d="M78 8h40" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.5"/>
        <path d="M60 2 62.4 6.2 67 7 63.8 10.3 64.6 15 60 12.8 55.4 15 56.2 10.3 53 7 57.6 6.2Z" fill="currentColor"/>
        <circle cx="46" cy="8" r="1.6" fill="currentColor" opacity="0.8"/>
        <circle cx="74" cy="8" r="1.6" fill="currentColor" opacity="0.8"/>
      </svg>
    </span>

    {%- if section.settings.paragraph_1 != blank -%}
      <p class="zk-story__text">{{ section.settings.paragraph_1 }}</p>
    {%- endif -%}

    {%- if section.settings.paragraph_2 != blank -%}
      <p class="zk-story__text">{{ section.settings.paragraph_2 }}</p>
    {%- endif -%}

    {%- if section.settings.paragraph_3 != blank -%}
      <p class="zk-story__text">{{ section.settings.paragraph_3 }}</p>
    {%- endif -%}

    {%- if section.settings.paragraph_4 != blank -%}
      <p class="zk-story__text">{{ section.settings.paragraph_4 }}</p>
    {%- endif -%}

    {%- if section.settings.quote != blank -%}
      <blockquote class="zk-story__quote">
        {{ section.settings.quote }}
      </blockquote>
    {%- endif -%}
  </div>
</section>

{%- comment -%} Reveal handled globally by snippets/zk-premium.liquid {%- endcomment -%}

{% schema %}
{
  "name": "Zekulhyda Poveste",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label (deasupra titlului)",
      "default": "Povestea noastră"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titlu secțiune",
      "default": "Scurtă Introducere"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraf 1",
      "default": "Povestea și producerea pălincii are o datină îndelungată pe Valea Ierului, tradiție pe care am dorit s-o păstrăm și s-o îmbinăm cu tehnologia modernă de ultimă generație și să lăsăm și noi ceva în urma noastră pentru cei care vor avea dorința de a duce mai departe ce am continuat și noi."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraf 2",
      "default": "În urmă cu ceva vreme, am început să producem pălinca, pălincă de înaltă calitate cu care să ne putem mândri oriunde în țară și în străinătate. Găsind pasiunea în arta de a face un destilat, am căutat soluții pentru a ajunge la țelul dorit, de a face ceva mai special, ani la rând studiind fermentarea, destilarea, bineînțeles totul controlat cu strictețe."
    },
    {
      "type": "textarea",
      "id": "paragraph_3",
      "label": "Paragraf 3",
      "default": "Am făcut primii pași spre ceva mai bun, ceva cu care sa fim prezenți la competiții mari din Europa, dar nu ne-am mulțumit cu atât."
    },
    {
      "type": "textarea",
      "id": "paragraph_4",
      "label": "Paragraf 4",
      "default": "Studiind în continuare și învățând din greșelile făcute, astăzi, am ajuns la o singură concluzie: fără suflet și dăruință nimic nu este posibil, așa cum credem că fructul, în momentul procesării, ne dă sufletul, tot așa trebuie să continuăm cu această idee care sună astfel:"
    },
    {
      "type": "text",
      "id": "quote",
      "label": "Citat / Motto",
      "default": "„Sufletul Fructului, va fi, Fructul Sufletului”"
    }
  ],
  "presets": [
    {
      "name": "Zekulhyda Poveste"
    }
  ]
}
{% endschema %}
